{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "agent/**",
      "*.md",
      "**/*.py",
      "**/*.sh",
      "**/*.exe",
      "**/*.bat",
      "**/*.cmd",
      "**/*.apk",
      "**/*.aab",
      "**/*.jar"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
